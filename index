}
.lib-empty{
  text-align:center;padding:28px 20px;
  background:var(--white);border:1px dashed var(--border2);
  border-radius:var(--r);
  font-size:12.5px;color:var(--ink3);line-height:1.6;
}
.lib-empty strong{color:var(--ink2);font-weight:600;}

.lib-grid{display:flex;flex-direction:column;gap:8px;}

.lib-item{
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--r-sm);padding:13px 16px;
  display:flex;align-items:center;gap:14px;
  transition:box-shadow 0.15s;
}
.lib-item:hover{box-shadow:var(--shadow);}

.lib-thumb{
  width:44px;height:44px;border-radius:7px;
  background:var(--paper2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;overflow:hidden;
}
.lib-thumb img{width:100%;height:100%;object-fit:cover;}
.lib-thumb-placeholder{font-size:18px;}

.lib-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;}
.lib-item-hook{font-size:13px;font-weight:600;color:var(--ink);letter-spacing:-0.2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lib-item-meta{display:flex;align-items:center;gap:8px;}
.lib-item-angle{font-size:10.5px;color:var(--ink3);}
.lib-item-note{font-size:10.5px;color:var(--ink3);font-style:italic;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;}

.status-pill{
