}

.input-inner{max-width:720px;margin:0 auto;display:flex;flex-direction:column;gap:8px;}

/* Mode bar */
.mode-bar{display:flex;gap:5px;overflow-x:auto;padding-bottom:1px;scrollbar-width:none;}
.mode-bar::-webkit-scrollbar{display:none;}
.mbar-btn{
  display:flex;align-items:center;gap:5px;
