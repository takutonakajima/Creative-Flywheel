async function scrapeUrl(){
  const url = document.getElementById('of-url').value.trim();
  if(!url){ alert('Paste a website URL first.'); return; }
  const btn = document.getElementById('scrapeBtn');
  const status = document.getElementById('scrape-status');
  btn.textContent = 'Fetching...'; btn.disabled = true;
  status.textContent = 'Reading website...';

  try{
    const r = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'anthropic-dangerous-direct-browser-access':'true'
      },
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1500,
        messages:[{role:'user',content:`Visit this med spa website and extract the following information. Return ONLY valid JSON, no markdown:\n\nURL: ${url}\n\n{"clinicName":"","location":"city, state","targetAudience":"best guess e.g. Women 28-55","services":"list each service with price on its own line e.g. HydraFacial — $200","currentOffers":"any promos or special pricing mentioned"}\n\nIf you cannot access the URL, make your best guess from the URL domain name alone and note it.`}]
      })
    });
    if(!r.ok) throw new Error('API error');
    const d = await r.json();
    const text = d.content.map(b=>b.text||'').join('').trim();
    const clean = text.replace(/```json\n?/g,'').replace(/```\n?/g,'').trim();
    const data = JSON.parse(clean);

    if(data.clinicName) document.getElementById('of-clinic').value = data.clinicName;
    if(data.location) document.getElementById('of-location').value = data.location;
    if(data.targetAudience) document.getElementById('of-audience').value = data.targetAudience;
    if(data.services) document.getElementById('of-services').value = data.services;
    if(data.currentOffers) document.getElementById('of-current').value = data.currentOffers;

    status.textContent = '✓ Fields filled — review and edit anything before generating.';
    status.style.color = 'var(--emerald)';
  }catch(err){
    status.textContent = 'Could not auto-fill — fill in the fields manually.';
    status.style.color = 'var(--fire)';
  }finally{
    btn.textContent = 'Auto-fill →'; btn.disabled = false;
  }
}

