  const prompt=unesc(card.dataset.prompt||'');const aspect=card.dataset.aspect||'ASPECT_1_1';
  const zone=document.getElementById(`iz-${cardId}`);if(!zone)return;
  const existing=zone.querySelector('img');if(existing)existing.remove();
  let genEl=document.getElementById(`ig-${cardId}`);
  if(!genEl){genEl=document.createElement('div');genEl.id=`ig-${cardId}`;zone.insertBefore(genEl,zone.querySelector('.iacts'));}
  genEl.className='igen';genEl.style.display='flex';
  genEl.innerHTML=`<div class="ibar"><div class="ibar-f"></div></div><div class="igen-txt">Regenerating...</div>`;
  await genImage(cardId,prompt,aspect);
}

function dlImg(cardId){
  const card=document.getElementById(cardId);
  const url=card?.dataset?.imgUrl||card?.querySelector('img')?.src;
  if(url)window.open(url,'_blank');
}

function copyCard(cardId,btn){
  const c=document.getElementById(cardId);
  const h=c.querySelector('.c-hook')?.innerText||'';
  const s=c.querySelector('.c-sub')?.innerText||'';
  const b=c.querySelector('.c-copy')?.innerText||'';
  const cta=c.querySelector('.c-cta-txt')?.innerText?.trim()||'';
  navigator.clipboard.writeText(`HEADLINE: ${h}${s?'\nSUBHEAD: '+s:''}\n\nCAPTION:\n${b}\n\nCTA: ${cta}`).then(()=>{
    btn.classList.add('ok');btn.innerHTML='✓ Copied';
    setTimeout(()=>{btn.classList.remove('ok');btn.innerHTML=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy`;},2000);
  });
}

async function sendCreative(){
  if(busy)return;
  const inp=document.getElementById('p');const txt=inp.value.trim();if(!txt)return;
  busy=true;inp.value='';inp.style.height='auto';document.getElementById('go').disabled=true;
  const mode=activeMode;const m=MODES[mode]||MODES.refresh;
  addUserMsg(txt);

  let userContent=`[Mode: ${m.label}] ${txt}`;
  if(offerCtx?.offer){
    userContent+=`\n\nOFFER CONTEXT: Client is ${offerCtx.clinic||'a med spa'}${offerCtx.location?' in '+offerCtx.location:''}. Offer: "${offerCtx.offer.headline}" — ${offerCtx.offer.priceStructure}. Why it converts: ${offerCtx.offer.conversionPsychology}`;
  }

  hist.push({role:'user',content:userContent});
  const spin=addSpinner(mode);

  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:4000,system:BASE_SYS+'\n\nMODE:\n'+m.sys,messages:hist})});
    clearInterval(spin._t);spin.remove();
    if(!r.ok){const e=await r.json();throw new Error(e.error?.message||'API error');}
    const d=await r.json();const reply=d.content.map(b=>b.text||'').join('');
    hist.push({role:'assistant',content:reply});
    addAIMsg(reply,mode);
  }catch(err){
    clearInterval(spin._t);spin.remove();
    addAIMsg(`Something went wrong: ${err.message}`,mode);
  }finally{
    busy=false;document.getElementById('go').disabled=false;inp.focus();
  }
}
</script>
