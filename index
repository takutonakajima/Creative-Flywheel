<script>
const PROXY='https://ideogram-proxy.takuto-nakajima.workers.dev';

/* ── TAB ── */
function switchTab(tab,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelector(`.tab[onclick*="${tab}"]`)?.classList.add('active');
  document.getElementById(`panel-${tab}`).classList.add('active');
}

/* ── MODES ── */
const MODES={
  refresh:{
    label:'Refresh',icon:'🔄',
    desc:'Same proven angles, completely fresh execution. Replace fatiguing ads without abandoning what works.',
    placeholder:'Paste the underperforming ad or describe what\'s fatiguing…',
    sys:'Keep the same proven angles but execute with completely new hooks, visuals, and energy. Generate 3 variations.'
  },
  innovate:{
    label:'Innovate',icon:'🔥',
    desc:'No rules. Push way outside the obvious. Find angles nobody else is running.',
    placeholder:'Describe the service and audience to generate a new breakthrough angle…',
    sys:'Full creative innovation mode. Ignore conventional med spa ads. Find surprising, culturally sharp, emotionally unexpected angles. Generate 4 bold variations, each completely different.'
  },
  ab:{
    label:'A/B Batch',icon:'🧪',
    desc:'Systematic variations that isolate one variable — hook, visual, CTA, or angle.',
    placeholder:'Create 6–10 variations of this winning angle to A/B test…',
    sys:'Build a structured A/B test batch. Generate exactly 4 variations changing ONE variable each time. Label clearly: Variation A (hook), B (CTA), C (visual), D (angle).'
  },
  seasonal:{
    label:'Seasonal',icon:'📅',
    desc:'Hook into the current cultural moment, season, or upcoming holiday.',
    placeholder:'Generate Mother\'s Day / summer / holiday campaign creatives…',
    sys:'Build seasonally-timed creatives. Hook into current cultural moments — season, holidays, timely emotions. Generate 3 variations with strong seasonal hooks.'
  },
  ugc:{
    label:'UGC',icon:'📱',
    desc:'Raw, authentic, creator-style content that feels real — not polished ad creative.',
    placeholder:'Create UGC-style ad concepts with hooks, scripts, and image prompts…',
    sys:'Create UGC-style video concepts. Should feel completely authentic — like a real customer filmed it on their phone. No polish. Generate 3 UGC concepts.'
  }
};

let activeMode='refresh',offerCtx=null,hist=[],busy=false;
let library=[]; // { id, hook, angle, mode, status, note, imgUrl, bodyCopy, cta }
updateModeDesc();
updateInputModeLabel();

function setMode(mode,el){
  activeMode=mode;
  document.querySelectorAll('#emptyModes .mode-pill-btn').forEach(b=>b.classList.toggle('on',b.dataset.mode===mode));
  document.querySelectorAll('#modeBar .mbar-btn').forEach(b=>b.classList.toggle('on',b.dataset.mode===mode));
  updateModeDesc();
  updateInputModeLabel();
  updatePlaceholder();
  document.getElementById('p').focus();
}

function updateModeDesc(){
  const el=document.getElementById('modeDesc');
  if(!el)return;
  el.style.opacity='0';
  setTimeout(()=>{el.textContent=MODES[activeMode]?.desc||'';el.style.opacity='1';},150);
}

function updateInputModeLabel(){
  const el=document.getElementById('inputModeLabel');
  if(!el)return;
  const m=MODES[activeMode]||MODES.refresh;
  el.innerHTML=`<span class="input-mode-icon">${m.icon}</span> ${m.label} mode`;
}

function updatePlaceholder(){
  const el=document.getElementById('p');
  if(!el)return;
  el.placeholder=MODES[activeMode]?.placeholder||'Describe what you need…';
}

function clearOfferCtx(){
  offerCtx=null;
  document.getElementById('selected-offer-card').style.display='none';
}

function updateSelectedOfferCard(){
  const card=document.getElementById('selected-offer-card');
  if(!offerCtx?.offer){card.style.display='none';return;}
  const o=offerCtx.offer;
  card.style.display='block';
  document.getElementById('soc-headline').textContent=o.headline||'—';
  document.getElementById('soc-audience').textContent=offerCtx.audience||o.targetedAt||'—';
  document.getElementById('soc-price').textContent=o.priceStructure||'—';
  document.getElementById('soc-hook').textContent=(o.hooks?.[0]||o.conversionPsychology||'').slice(0,48)+'…';
  document.getElementById('soc-cta').textContent=o.type||'View offer';
}

/* ── HELPERS ── */
