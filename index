  font-family:'Geist',sans-serif;white-space:nowrap;flex-shrink:0;
}
.mbar-btn:hover{border-color:var(--border2);color:var(--ink);}
.mbar-btn.on{background:var(--ink);border-color:var(--ink);color:var(--white);}
.mbar-icon{font-size:13px;}

/* Input box */
.input-box{
  display:flex;align-items:flex-end;gap:8px;
  background:var(--white);
