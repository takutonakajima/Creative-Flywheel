.status-fatigued{background:rgba(217,79,43,0.08);color:var(--fire);border:1px solid var(--fire-bd);}
.status-archived{background:var(--paper2);color:var(--ink3);border:1px solid var(--border);}

.lib-actions{display:flex;gap:6px;flex-shrink:0;}
.lib-btn{
