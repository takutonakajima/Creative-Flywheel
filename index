}
#p::placeholder{color:var(--ink3);}

.send-btn{
  width:34px;height:34px;
  background:var(--ink);border:none;border-radius:9px;
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all 0.18s cubic-bezier(0.34,1.4,0.64,1);
}
.send-btn:hover{background:var(--fire);transform:scale(1.06);}
.send-btn:active{transform:scale(0.96);}
.send-btn:disabled{opacity:0.2;cursor:not-allowed;transform:none;}
.send-btn svg{width:14px;height:14px;}

.input-hint{
  text-align:center;font-size:11px;color:var(--ink3);
  font-family:'Geist',sans-serif;
}

@media(max-width:640px){
  header{padding:0 16px;grid-template-columns:1fr auto;}
  .header-right{display:none;}
  .input-area,.msgs-inner,.offer-layout,.offer-results-layout,.offer-banner{padding-left:16px;padding-right:16px;}
  .creative-empty{padding:28px 16px;}
  .field-group{grid-template-columns:1fr;}
  .c-hook{font-size:20px;}
  .offer-headline-big{font-size:20px;}
}
