<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creative Flywheel</title>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}

:root{
  --paper:#F5F3EE;
  --paper2:#EDEAE3;
  --white:#FFFFFF;
  --ink:#141210;
  --ink2:#6E6A63;
  --ink3:#B0AC A4;
  --ink3:#B0ACA4;
  --ink4:#D8D4CC;
  --fire:#D94F2B;
  --fire-dim:rgba(217,79,43,0.08);
  --fire-bd:rgba(217,79,43,0.18);
  --emerald:#1A7F5A;
  --emerald-dim:rgba(26,127,90,0.08);
  --emerald-bd:rgba(26,127,90,0.2);
  --border:#E4E0D8;
  --border2:#CCC8BF;
  --shadow:0 1px 3px rgba(20,18,16,0.06),0 4px 16px rgba(20,18,16,0.06);
  --shadow-lg:0 8px 40px rgba(20,18,16,0.10),0 2px 8px rgba(20,18,16,0.05);
  --r:14px;--r-sm:9px;
}

html,body{height:100%;overflow:hidden;}

body{
  font-family:'Geist',sans-serif;
  background:var(--paper);
  color:var(--ink);
  display:flex;flex-direction:column;
  height:100vh;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}

/* ─── HEADER ─── */
header{
  flex-shrink:0;
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  padding:0 32px;
  height:58px;
  background:rgba(245,243,238,0.92);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  position:relative;z-index:100;
}

.logo{
  display:flex;align-items:center;gap:10px;
}

.logo-mark{
  width:30px;height:30px;
  background:var(--ink);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.logo-mark::after{
  content:'';position:absolute;inset:0;
  background:conic-gradient(from 180deg,transparent,rgba(255,255,255,0.07),transparent);
  animation:lspin 8s linear infinite;
}
@keyframes lspin{to{transform:rotate(360deg)}}
.logo-mark svg{width:16px;height:16px;position:relative;z-index:1;}

.logo-name{
  font-family:'Geist',sans-serif;
  font-size:14px;font-weight:600;
  color:var(--ink);letter-spacing:-0.3px;
}

/* center tabs */
.tabs{
  display:flex;align-items:center;gap:2px;
  background:var(--paper2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:3px;
}

.tab{
  display:flex;align-items:center;gap:6px;
  padding:6px 16px;border-radius:7px;
  font-size:12.5px;font-weight:500;
  color:var(--ink2);
  cursor:pointer;transition:all 0.18s;
  border:none;background:none;
  font-family:'Geist',sans-serif;
  white-space:nowrap;
}
.tab:hover{color:var(--ink);}
.tab.active{
  background:var(--white);
  color:var(--ink);
  box-shadow:0 1px 4px rgba(20,18,16,0.10);
  font-weight:600;
}
.tab-icon{font-size:14px;}

.header-right{
  display:flex;justify-content:flex-end;align-items:center;gap:8px;
}
.live-chip{
  display:flex;align-items:center;gap:6px;
  font-size:11px;font-weight:500;color:var(--ink3);
  padding:5px 11px;
  background:var(--white);
  border:1px solid var(--border);
  border-radius:20px;
}
.live-dot{
  width:6px;height:6px;border-radius:50%;
  background:#22C55E;
  box-shadow:0 0 0 2px rgba(34,197,94,0.2);
  animation:livepulse 2.5s ease-in-out infinite;
}
@keyframes livepulse{0%,100%{box-shadow:0 0 0 2px rgba(34,197,94,0.15)}50%{box-shadow:0 0 0 5px rgba(34,197,94,0.06)}}

/* ─── PANELS ─── */
.panel{display:none;flex:1;overflow:hidden;flex-direction:column;min-height:0;}
.panel.active{display:flex;}

/* ─── SCROLLABLE INNER ─── */
.scroll{flex:1;overflow-y:auto;display:flex;flex-direction:column;}
.scroll::-webkit-scrollbar{width:4px;}
.scroll::-webkit-scrollbar-track{background:transparent;}
.scroll::-webkit-scrollbar-thumb{background:var(--ink4);border-radius:4px;}

/* ─── OFFER PANEL ─── */
.offer-layout{
  max-width:660px;width:100%;
  margin:0 auto;padding:36px 28px 48px;
}

.section-eyebrow{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;
  letter-spacing:2.5px;text-transform:uppercase;
  color:var(--ink3);margin-bottom:10px;
}

.offer-title{
  
  font-size:clamp(28px,4vw,40px);
  font-weight:700;line-height:1.03;
  letter-spacing:-2px;color:var(--ink);
  margin-bottom:8px;
}
.offer-title em{font-style:normal;color:var(--fire);}

.offer-sub{
  font-size:14px;font-weight:300;
  color:var(--ink2);line-height:1.7;
  margin-bottom:32px;max-width:440px;
}

/* Form */
.form-grid{display:flex;flex-direction:column;gap:14px;}
.field-group{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

.field{display:flex;flex-direction:column;gap:5px;}
.field label{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;
  letter-spacing:2px;text-transform:uppercase;
  color:var(--ink3);
}
.field input,.field textarea,.field select{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r-sm);
  padding:10px 14px;
  font-size:13.5px;font-weight:400;
  font-family:'Geist',sans-serif;
  color:var(--ink);
  outline:none;
  transition:border-color 0.15s,box-shadow 0.15s;
  width:100%;resize:none;
  appearance:none;-webkit-appearance:none;
}
.field input:focus,.field textarea:focus,.field select:focus{
  border-color:var(--ink);
  box-shadow:0 0 0 3px rgba(20,18,16,0.06);
}
.field input::placeholder,.field textarea::placeholder{color:var(--ink4);}
.field textarea{min-height:90px;line-height:1.6;}
.field select{
  background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23B0ACA4' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat;
  background-position:right 14px center;
  padding-right:36px;cursor:pointer;
}
.field select option{background:var(--white);color:var(--ink);}

.gen-btn{
  width:100%;
  background:var(--ink);border:none;
  border-radius:var(--r-sm);
  padding:14px 24px;
  font-family:'Geist',sans-serif;
  font-size:14px;font-weight:600;
  color:var(--white);
  cursor:pointer;
  transition:all 0.2s cubic-bezier(0.34,1.2,0.64,1);
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-top:6px;
  letter-spacing:-0.2px;
}
.gen-btn:hover{background:var(--fire);transform:translateY(-1px);box-shadow:0 4px 16px rgba(217,79,43,0.25);}
.gen-btn:disabled{opacity:0.3;cursor:not-allowed;transform:none;box-shadow:none;}

/* Offer results */
.offer-results-layout{
  max-width:660px;width:100%;
  margin:0 auto;padding:32px 28px 48px;
}

.results-header{
  display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:24px;gap:16px;
}
.results-header-left{}
.results-title{
  
  font-size:26px;font-weight:700;
  letter-spacing:-1px;color:var(--ink);
  margin-bottom:3px;
}
.results-sub{font-size:12px;color:var(--ink3);}

.back-btn{
  display:flex;align-items:center;gap:5px;
  background:var(--white);border:1px solid var(--border);
  border-radius:var(--r-sm);padding:7px 13px;
  font-size:12px;font-weight:500;color:var(--ink2);
  cursor:pointer;transition:all 0.12s;font-family:'Geist',sans-serif;
  white-space:nowrap;flex-shrink:0;
}
.back-btn:hover{border-color:var(--border2);color:var(--ink);}

/* Offer card */
.offer-card{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r);
  overflow:hidden;
  margin-bottom:14px;
  box-shadow:var(--shadow);
  transition:box-shadow 0.2s,transform 0.2s;
}
.offer-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-1px);}

.offer-card-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 20px;
  background:var(--paper);
  border-bottom:1px solid var(--border);
}

.offer-rank-row{display:flex;align-items:center;gap:8px;}

.rank-pill{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;
  letter-spacing:1.5px;text-transform:uppercase;
  padding:4px 10px;border-radius:20px;
}
.rank-1{background:rgba(180,130,20,0.1);color:#92600A;border:1px solid rgba(180,130,20,0.2);}
.rank-2{background:var(--paper2);color:var(--ink2);border:1px solid var(--border);}
.rank-3{background:var(--paper2);color:var(--ink2);border:1px solid var(--border);}

.offer-type-pill{
  font-size:10px;font-weight:600;
  letter-spacing:0.5px;text-transform:uppercase;
  padding:3px 10px;border-radius:20px;
  background:var(--fire-dim);border:1px solid var(--fire-bd);color:var(--fire);
}

.offer-card-body{
  padding:22px 20px;
  display:flex;flex-direction:column;gap:18px;
}

.offer-headline-big{
  
  font-size:22px;font-weight:700;
  line-height:1.1;letter-spacing:-0.8px;
  color:var(--ink);
}
.offer-price-line{
  font-size:13px;font-weight:600;
  color:var(--fire);margin-top:3px;
  letter-spacing:-0.1px;
}

.offer-row{display:flex;flex-direction:column;gap:4px;}
.offer-lbl{
  font-family:'Geist Mono',monospace;
  font-size:8.5px;font-weight:500;
  letter-spacing:2px;text-transform:uppercase;color:var(--ink3);
}
.offer-val{font-size:13px;color:var(--ink2);line-height:1.7;}

.hooks-row{display:flex;flex-wrap:wrap;gap:6px;}
.hook-chip{
  font-size:12px;font-weight:400;
  padding:5px 12px;border-radius:20px;
  background:var(--paper);border:1px solid var(--border);
  color:var(--ink2);
}

.why-box{
  display:flex;gap:12px;
  padding:14px 16px;
  background:var(--emerald-dim);border:1px solid var(--emerald-bd);
  border-radius:10px;
}
.why-icon{font-size:14px;flex-shrink:0;margin-top:1px;}
.why-text{font-size:12.5px;color:var(--ink2);line-height:1.7;font-style:italic;}

.watch-box{
  font-size:12px;color:var(--ink3);
  font-style:italic;line-height:1.6;
  padding-top:14px;border-top:1px solid var(--border);
}

.offer-card-footer{
  display:flex;justify-content:space-between;align-items:center;
  padding:12px 20px;
  border-top:1px solid var(--border);
  background:var(--paper);
  gap:8px;
}

.btn{
  display:flex;align-items:center;gap:5px;
  border-radius:7px;padding:6px 13px;
  font-size:11.5px;font-weight:600;
  cursor:pointer;transition:all 0.12s;
  font-family:'Geist',sans-serif;
  border:1px solid transparent;
}
.btn-ghost{background:var(--white);border-color:var(--border);color:var(--ink2);}
.btn-ghost:hover{border-color:var(--border2);color:var(--ink);}
.btn-dark{background:var(--ink);color:var(--white);border-color:var(--ink);}
.btn-dark:hover{background:var(--fire);}
.btn.ok{color:var(--emerald);border-color:rgba(26,127,90,0.25);background:var(--emerald-dim);}

/* ─── CREATIVE PANEL ─── */
.creative-empty{
  flex:1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:40px 28px;text-align:center;gap:20px;
}

.ce-eyebrow{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;letter-spacing:2.5px;
  text-transform:uppercase;color:var(--ink3);
}

.ce-title{
  
  font-size:clamp(32px,5vw,52px);
  font-weight:700;line-height:1.02;
  letter-spacing:-2.5px;color:var(--ink);
}
.ce-title em{font-style:normal;color:var(--fire);}

.ce-sub{font-size:14px;font-weight:300;color:var(--ink2);line-height:1.7;max-width:360px;}

/* Mode pills on empty state */
.mode-pills-wrap{display:flex;flex-wrap:wrap;gap:7px;justify-content:center;max-width:500px;}
.mode-pill-btn{
  display:flex;align-items:center;gap:6px;
  padding:8px 16px;
  background:var(--white);border:1.5px solid var(--border);
  border-radius:24px;
  font-size:12.5px;font-weight:500;color:var(--ink2);
  cursor:pointer;transition:all 0.15s;
  font-family:'Geist',sans-serif;
}
.mode-pill-btn:hover{border-color:var(--border2);color:var(--ink);}
.mode-pill-btn.on{background:var(--ink);border-color:var(--ink);color:var(--white);}
.mode-icon{font-size:14px;}

.mode-desc-txt{
  font-size:12.5px;font-weight:300;color:var(--ink3);
  max-width:320px;line-height:1.6;
  min-height:34px;transition:opacity 0.18s;
}

/* Chat messages */
.msgs-area{
  flex:1;overflow-y:auto;display:flex;flex-direction:column;min-height:0;
}
.msgs-area::-webkit-scrollbar{width:4px;}
.msgs-area::-webkit-scrollbar-thumb{background:var(--ink4);border-radius:4px;}

.msgs-inner{
  max-width:720px;width:100%;margin:0 auto;
  padding:24px 28px 12px;
  display:flex;flex-direction:column;gap:22px;
}

.msg{display:flex;flex-direction:column;gap:6px;animation:msgup 0.22s ease both;}
@keyframes msgup{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
.msg.user{align-items:flex-end;}
.msg.ai{align-items:flex-start;}

.msg-who{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;letter-spacing:1.5px;
  text-transform:uppercase;color:var(--ink3);padding:0 3px;
}

.user-bubble{
  max-width:68%;background:var(--ink);color:#F5F3EE;
  border-radius:16px;border-bottom-right-radius:4px;
  padding:12px 18px;font-size:14px;font-weight:400;line-height:1.6;
}

.ai-bubble{
  background:var(--white);border:1px solid var(--border);
  border-radius:16px;border-bottom-left-radius:4px;
  padding:20px 22px;width:100%;
  box-shadow:var(--shadow);
  font-size:14px;line-height:1.7;color:var(--ink2);
}

/* Thinking */
.thinking{
  display:flex;align-items:center;gap:10px;
  padding:11px 16px;background:var(--white);border:1px solid var(--border);
  border-radius:14px;border-bottom-left-radius:4px;
  font-size:11.5px;font-weight:500;color:var(--ink3);
  width:fit-content;font-family:'Geist',sans-serif;
}
.dots{display:flex;gap:4px;align-items:center;}
.dots span{width:4px;height:4px;border-radius:50%;background:var(--fire);opacity:0.3;animation:td 1.2s ease-in-out infinite;}
.dots span:nth-child(2){animation-delay:0.15s;}.dots span:nth-child(3){animation-delay:0.3s;}
@keyframes td{0%,80%,100%{opacity:0.2;transform:scale(0.8)}40%{opacity:1;transform:scale(1)}}

/* Offer context banner */
.offer-banner{
  max-width:720px;width:100%;margin:0 auto;
  padding:12px 28px 0;
}
.offer-banner-inner{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--emerald-dim);border:1px solid var(--emerald-bd);
  border-radius:9px;padding:9px 14px;
}
.offer-banner-txt{font-size:12px;font-weight:500;color:var(--emerald);}
.offer-banner-clear{background:none;border:none;font-size:11px;color:var(--ink3);cursor:pointer;font-family:'Geist',sans-serif;}
.offer-banner-clear:hover{color:var(--ink);}

/* Creative cards */
.cards-out{display:flex;flex-direction:column;}
.cards-lead{font-size:13.5px;color:var(--ink2);line-height:1.7;margin-bottom:16px;font-style:italic;}

.ccard{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r);overflow:hidden;
  margin-bottom:12px;
  box-shadow:var(--shadow);
  transition:box-shadow 0.18s,transform 0.18s;
}
.ccard:hover{box-shadow:var(--shadow-lg);transform:translateY(-1px);}

.ccard-top{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 18px;background:var(--paper);
  border-bottom:1px solid var(--border);
}
.ctags{display:flex;gap:6px;flex-wrap:wrap;align-items:center;}
.ctag{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;letter-spacing:1px;text-transform:uppercase;
  padding:3px 9px;border-radius:20px;
  background:var(--white);border:1px solid var(--border);color:var(--ink2);
}
.ctag.accent{background:var(--fire-dim);border-color:var(--fire-bd);color:var(--fire);}
.ccard-num{
  font-family:'Geist Mono',monospace;
  font-size:10px;color:var(--ink4);letter-spacing:1px;
}

/* Image zone */
.izone{
  width:100%;aspect-ratio:1/1;
  background:var(--paper2);
  position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  border-bottom:1px solid var(--border);
}
.izone.story{aspect-ratio:9/16;max-height:420px;}
.izone img{width:100%;height:100%;object-fit:cover;display:block;animation:fadeimg 0.4s ease;}
@keyframes fadeimg{from{opacity:0}to{opacity:1}}

.igen{
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;
  color:var(--ink3);
}
.ibar{width:90px;height:2px;background:var(--border);border-radius:2px;overflow:hidden;}
.ibar-f{height:100%;background:var(--fire);border-radius:2px;animation:ibf 2s ease-in-out infinite;}
@keyframes ibf{0%{width:0}70%{width:88%}100%{width:88%;opacity:0.3}}
.igen-txt{font-size:10px;font-weight:500;letter-spacing:0.3px;font-family:'Geist Mono',monospace;}

.iacts{position:absolute;bottom:10px;right:10px;display:flex;gap:5px;opacity:0;transition:opacity 0.15s;}
.izone:hover .iacts{opacity:1;}
.iact{
  display:flex;align-items:center;gap:4px;
  background:rgba(20,18,16,0.75);backdrop-filter:blur(10px);
  border:none;border-radius:6px;padding:5px 10px;
  font-size:10px;font-weight:600;color:white;
  cursor:pointer;font-family:'Geist',sans-serif;
  transition:background 0.12s;letter-spacing:0.2px;
}
.iact:hover{background:rgba(20,18,16,0.92);}

.ierr{
  display:flex;flex-direction:column;align-items:center;gap:7px;
  color:var(--ink3);
}
.ierr-btn{background:none;border:none;color:var(--fire);cursor:pointer;font-size:11px;font-weight:600;font-family:'Geist',sans-serif;}

/* Card body */
.ccard-body{padding:18px 18px;display:flex;flex-direction:column;gap:15px;}
.c-row{display:flex;flex-direction:column;gap:4px;}
.c-lbl{
  font-family:'Geist Mono',monospace;
  font-size:8.5px;font-weight:500;
  letter-spacing:2px;text-transform:uppercase;color:var(--ink3);
}
.c-hook{
  
  font-size:22px;font-weight:700;
  line-height:1.08;letter-spacing:-0.8px;color:var(--ink);
}
.c-sub{font-size:13px;font-weight:500;color:var(--fire);margin-top:2px;}
.c-copy{font-size:13px;font-weight:400;color:var(--ink2);line-height:1.8;}
.c-cta{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--ink);border-radius:10px;
  padding:10px 16px;width:fit-content;
}
.c-cta-txt{font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:#F5F3EE;}
.c-why{
  font-size:12px;color:var(--ink3);
  line-height:1.65;font-style:italic;
  padding-top:12px;border-top:1px solid var(--border);
}

.ccard-footer{
  display:flex;justify-content:flex-end;
  padding:10px 18px;
  border-top:1px solid var(--border);
  background:var(--paper);
}

.c-copy-btn{
  display:flex;align-items:center;gap:5px;
  background:var(--white);border:1px solid var(--border);
  border-radius:7px;padding:5px 12px;
  font-size:11px;font-weight:600;color:var(--ink2);
  cursor:pointer;transition:all 0.12s;font-family:'Geist',sans-serif;
}
.c-copy-btn:hover{border-color:var(--border2);color:var(--ink);}
.c-copy-btn.ok{color:var(--emerald);border-color:rgba(26,127,90,0.25);background:var(--emerald-dim);}

.cards-hint{font-size:11px;color:var(--ink3);text-align:center;padding:4px 0 8px;letter-spacing:0.3px;}

/* ─── SELECTED OFFER CARD ─── */
.selected-offer-card{
  max-width:720px;width:100%;margin:0 auto;
  padding:14px 28px 0;
}
.soc-inner{
  background:var(--white);
  border:1px solid var(--border);
  border-radius:var(--r);
  padding:14px 18px;
  display:flex;align-items:center;gap:16px;
  box-shadow:var(--shadow);
}
.soc-left{flex:1;min-width:0;display:flex;flex-direction:column;gap:3px;}
.soc-eyebrow{
  font-family:'Geist Mono',monospace;
  font-size:8.5px;font-weight:500;letter-spacing:2px;text-transform:uppercase;
  color:var(--emerald);display:flex;align-items:center;gap:5px;
}
.soc-eyebrow::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--emerald);flex-shrink:0;}
.soc-headline{font-size:14px;font-weight:700;color:var(--ink);letter-spacing:-0.3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.soc-meta{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.soc-chip{
  font-size:10px;font-weight:500;color:var(--ink2);
  display:flex;align-items:center;gap:4px;
}
.soc-chip-dot{width:3px;height:3px;border-radius:50%;background:var(--ink4);}
.soc-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.soc-change{
  font-size:11px;font-weight:500;color:var(--ink3);
  background:none;border:none;cursor:pointer;
  font-family:'Geist',sans-serif;
  text-decoration:underline;text-underline-offset:2px;
}
.soc-change:hover{color:var(--ink);}
.soc-cta-pill{
  font-size:10px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;
  background:var(--ink);color:var(--white);
  border-radius:20px;padding:4px 10px;
}

/* ─── CREATIVE LIBRARY ─── */
.library-section{
  max-width:720px;width:100%;margin:0 auto;
  padding:0 28px 40px;
}
.lib-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
  padding-top:28px;
  border-top:1px solid var(--border);
}
.lib-title{
  display:flex;align-items:center;gap:8px;
  font-size:13px;font-weight:700;color:var(--ink);letter-spacing:-0.2px;
}
.lib-count{
  font-family:'Geist Mono',monospace;
  font-size:9px;font-weight:500;
  background:var(--paper2);border:1px solid var(--border);
